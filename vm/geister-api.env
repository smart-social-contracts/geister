# Geister API environment variables for VM deployment
# Used by docker-compose.yml and dev.sh

# Ollama runs on the pod, accessed via Cloudflare tunnel
OLLAMA_URL=https://geister-ollama.realmsgos.dev

# LLM model
DEFAULT_LLM_MODEL=gpt-oss:20b

# PostgreSQL
# Docker: DB_HOST=postgres (service name in docker-compose)
# Dev:    DB_HOST=localhost (overridden by dev.sh)
DB_HOST=postgres
DB_NAME=geister_db
DB_USER=geister_user
DB_PASS=geister_pass
DB_PORT=5432

# DFX
DFX_WARNING=-mainnet_plaintext_identity
GEISTER_USE_LLM=true
GEISTER_DFX_NETWORK=ic

# Auto-stop RunPod pod after 1h with no API requests (see api.py monitor_inactivity)
INACTIVITY_TIMEOUT_SECONDS=3600

# Max wait when auto-starting a stopped pod before returning 503
OLLAMA_READY_TIMEOUT_SECONDS=300

# dfx project with test/staging network definitions for realm tool calls
REALMS_PROJECT_DIR=/srv/dev1/realms
